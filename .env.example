# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://lidox:lidox_dev@localhost:5432/lidox
POSTGRES_USER=lidox
POSTGRES_PASSWORD=lidox_dev
POSTGRES_DB=lidox

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT / Auth ────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OAuth SSO (optional for PoC) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── AI / Groq ─────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...
# Optional: override default model
# GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ─── Services ──────────────────────────────────────────────
API_PORT=3001
SYNC_PORT=3002
WEB_PORT=5173
CORS_ORIGIN=http://localhost:5173
