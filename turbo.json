{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "build/**"]
		},
		"test:unit": {
			"dependsOn": ["build"],
			"inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts"]
		},
		"lint": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
